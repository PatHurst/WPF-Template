<Window
    x:Class="WPFTemplate.App.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="WPFTemplate"
    MinWidth="800"
    MinHeight="450"
    Background="{DynamicResource WindowBackground}"
    StateChanged="OnStateChanged"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="38"
            GlassFrameThickness="0"
            ResizeBorderThickness="5"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <!--  Standard title-bar button  -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TitleBarForeground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!--  Inset rounded rect — only this lights up, not the full button area  -->
                            <Border
                                x:Name="Bg"
                                Margin="6,7"
                                Background="Transparent"
                                CornerRadius="4" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource TitleBarButtonHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource TitleBarButtonHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Close button — red hover  -->
        <Style
            x:Key="TitleBarCloseButton"
            BasedOn="{StaticResource TitleBarButton}"
            TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border
                                x:Name="Bg"
                                Margin="6,7"
                                Background="Transparent"
                                CornerRadius="4" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource TitleBarButtonClose}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource TitleBarButtonClose}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel>

        <!--  ── Custom Title Bar ──────────────────────────────────────────  -->
        <Grid
            Height="38"
            Background="{DynamicResource TitleBarBackground}"
            DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Margin="12,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource TitleBarForeground}"
                Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button
                    x:Name="MinimizeButton"
                    Click="OnMinimizeClick"
                    Content="&#x2212;"
                    Style="{StaticResource TitleBarButton}" />
                <Button
                    x:Name="MaximizeButton"
                    Click="OnMaximizeClick"
                    Content="&#x25A1;"
                    Style="{StaticResource TitleBarButton}" />
                <Button
                    Click="OnCloseClick"
                    Content="&#x00D7;"
                    Style="{StaticResource TitleBarCloseButton}" />
            </StackPanel>
        </Grid>

        <!--  ── Menu Bar ────────────────────────────────────────────────  -->
        <Menu DataContext="{Binding Menu}" DockPanel.Dock="Top">

            <MenuItem Header="_File">
                <MenuItem Command="{Binding ExitCommand}" Header="E_xit" />
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Command="{Binding NavigateHomeCommand}" Header="_Home" />
                <MenuItem Command="{Binding NavigateLogCommand}" Header="_Log Demo" />
            </MenuItem>

            <MenuItem Header="_Settings">
                <MenuItem Header="_Appearance">
                    <MenuItem Header="_Theme" ItemsSource="{Binding SetThemeCommands}">
                        <MenuItem.ItemContainerStyle>
                            <Style BasedOn="{StaticResource {x:Type MenuItem}}" TargetType="MenuItem">
                                <Setter Property="Command" Value="{Binding}" />
                                <Setter Property="Header" Value="{Binding Header}" />
                                <Setter Property="IsChecked" Value="{Binding IsActive, Mode=OneWay}" />
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                    <MenuItem Header="_Accent Color" ItemsSource="{Binding SetAccentColorCommands}">
                        <MenuItem.ItemContainerStyle>
                            <Style BasedOn="{StaticResource {x:Type MenuItem}}" TargetType="MenuItem">
                                <Setter Property="Command" Value="{Binding}" />
                                <Setter Property="Icon" Value="{Binding Icon}" />
                                <Setter Property="Header" Value="{Binding Header}" />
                                <Setter Property="IsChecked" Value="{Binding IsActive, Mode=OneWay}" />
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                    <MenuItem Header="_Font" ItemsSource="{Binding SetFontCommands}">
                        <MenuItem.ItemContainerStyle>
                            <Style BasedOn="{StaticResource {x:Type MenuItem}}" TargetType="MenuItem">
                                <Setter Property="Command" Value="{Binding}" />
                                <Setter Property="Header" Value="{Binding Header}" />
                                <Setter Property="IsChecked" Value="{Binding IsActive, Mode=OneWay}" />
                                <Setter Property="FontFamily" Value="{Binding Header}" />
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Command="{Binding ShowAboutCommand}" Header="_About WPFTemplate" />
            </MenuItem>

        </Menu>

        <!--  ── Status Bar ─────────────────────────────────────────────  -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding StatusText}" />
        </StatusBar>

        <!--  ── Page content ───────────────────────────────────────────  -->
        <ContentControl Content="{Binding Navigation.CurrentView}" />

    </DockPanel>
</Window>
