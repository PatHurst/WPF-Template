<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ═══════════════════════════════════════════════════
        CLASSIC THEME — Windows 2000 / XP Classic
        Square corners, raised system-gray surfaces, navy title bar.
        ════════════════════════════════════════════════════
    -->

    <!--  Corner radii — square everything  -->
    <CornerRadius x:Key="CornerSmall">0</CornerRadius>
    <CornerRadius x:Key="CornerNormal">0</CornerRadius>
    <CornerRadius x:Key="CornerLarge">0</CornerRadius>

    <!--  Window / Shell  -->
    <SolidColorBrush x:Key="WindowBackground" Color="#D4D0C8" />
    <SolidColorBrush x:Key="WindowBorder" Color="#808080" />

    <!--  Sidebar / Panel  -->
    <SolidColorBrush x:Key="SidebarBackground" Color="#D4D0C8" />
    <SolidColorBrush x:Key="SidebarBorder" Color="#808080" />
    <SolidColorBrush x:Key="SidebarItemHover" Color="#BDD4ED" />
    <SolidColorBrush x:Key="SidebarItemSelected" Color="#316AC5" />

    <!--  Title Bar  -->
    <SolidColorBrush x:Key="TitleBarBackground" Color="#000080" />
    <SolidColorBrush x:Key="TitleBarForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TitleBarButtonHover" Color="#1084D0" />
    <SolidColorBrush x:Key="TitleBarButtonClose" Color="#C42B1C" />

    <!--  Menu Bar  -->
    <SolidColorBrush x:Key="MenuBackground" Color="#D4D0C8" />
    <SolidColorBrush x:Key="MenuBorder" Color="#808080" />
    <SolidColorBrush x:Key="MenuItemBackground" Color="Transparent" />
    <SolidColorBrush x:Key="MenuItemHover" Color="#000080" />
    <SolidColorBrush x:Key="MenuItemForeground" Color="#000000" />
    <SolidColorBrush x:Key="MenuSeparator" Color="#808080" />
    <SolidColorBrush x:Key="SubMenuBackground" Color="#D4D0C8" />
    <SolidColorBrush x:Key="SubMenuBorder" Color="#808080" />

    <!--  Toolbar / Breadcrumb  -->
    <SolidColorBrush x:Key="ToolbarBackground" Color="#D4D0C8" />
    <SolidColorBrush x:Key="ToolbarBorder" Color="#808080" />
    <SolidColorBrush x:Key="BreadcrumbForeground" Color="#000000" />
    <SolidColorBrush x:Key="BreadcrumbSeparator" Color="#808080" />

    <!--  Content Area  -->
    <SolidColorBrush x:Key="ContentBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ContentBorder" Color="#808080" />

    <!--  List / Grid  -->
    <SolidColorBrush x:Key="ListBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ListItemBackground" Color="Transparent" />
    <SolidColorBrush x:Key="ListItemHover" Color="#BDD4ED" />
    <SolidColorBrush x:Key="ListItemSelected" Color="#316AC5" />
    <SolidColorBrush x:Key="ListItemSelectedFocus" Color="#3169BE" />
    <SolidColorBrush x:Key="ListHeaderBackground" Color="#D4D0C8" />
    <SolidColorBrush x:Key="ListHeaderBorder" Color="#808080" />
    <SolidColorBrush x:Key="ListHeaderForeground" Color="#000000" />
    <SolidColorBrush x:Key="ListSeparator" Color="#C0C0C0" />
    <SolidColorBrush x:Key="ListGridLine" Color="#D4D0C8" />

    <!--  Status Bar  -->
    <SolidColorBrush x:Key="StatusBarBackground" Color="#D4D0C8" />
    <SolidColorBrush x:Key="StatusBarForeground" Color="#000000" />
    <SolidColorBrush x:Key="StatusBarBorder" Color="#808080" />

    <!--  Text  -->
    <SolidColorBrush x:Key="TextPrimary" Color="#000000" />
    <SolidColorBrush x:Key="TextSecondary" Color="#444444" />
    <SolidColorBrush x:Key="TextDisabled" Color="#808080" />

    <!--  Controls  -->
    <SolidColorBrush x:Key="ControlBackground" Color="#D4D0C8" />
    <SolidColorBrush x:Key="ControlBorder" Color="#808080" />
    <SolidColorBrush x:Key="ControlHover" Color="#E0DDD8" />
    <SolidColorBrush x:Key="ControlPressed" Color="#B8B5AF" />
    <SolidColorBrush x:Key="ControlDisabled" Color="#D4D0C8" />
    <SolidColorBrush x:Key="ControlDisabledBorder" Color="#AAAAAA" />

    <!--  Scrollbar  -->
    <SolidColorBrush x:Key="ScrollbarTrack" Color="#D4D0C8" />
    <SolidColorBrush x:Key="ScrollbarThumb" Color="#A0A0A0" />
    <SolidColorBrush x:Key="ScrollbarThumbHover" Color="#808080" />
    <SolidColorBrush x:Key="ScrollbarThumbPressed" Color="#606060" />

    <!--  Input  -->
    <SolidColorBrush x:Key="InputBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputBorder" Color="#808080" />
    <SolidColorBrush x:Key="InputForeground" Color="#000000" />
    <SolidColorBrush x:Key="InputPlaceholder" Color="#808080" />

    <!--  Tooltip  -->
    <SolidColorBrush x:Key="TooltipBackground" Color="#FFFFCC" />
    <SolidColorBrush x:Key="TooltipBorder" Color="#000000" />
    <SolidColorBrush x:Key="TooltipForeground" Color="#000000" />

    <!--  Section Headers  -->
    <SolidColorBrush x:Key="GroupHeaderForeground" Color="#444444" />

    <!--  Overlay / Modal  -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#60000000" />


</ResourceDictionary>
